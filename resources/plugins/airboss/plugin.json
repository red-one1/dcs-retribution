{
    "nameInUI": "Moose Airboss",
    "defaultValue": false,
    "specificOptions": [        
        {
            "nameInUI": "Enable Airboss for LHA",
            "mnemonic": "enableForLHA",
            "defaultValue": true
        },
        {
            "nameInUI": "Enable Airboss Recovery Tanker",
            "mnemonic": "enableTanker",
            "defaultValue": false
        },
        {
            "nameInUI": "Enable Airboss AWACS",
            "mnemonic": "enableAWACS",
            "defaultValue": false
        },
        {
            "nameInUI": "Enable Airboss Rescue Helo (Required for MSRS)",
            "mnemonic": "enableRescueHelo",
            "defaultValue": true
        },
        {
            "nameInUI": "Rescue Helo Max Distance (nm)",
            "mnemonic": "rescueHeloDistance",
            "minimumValue": 5,
            "maximumValue": 120,
            "defaultValue": 50
        },
        {
            "nameInUI": "Use UH-60L Mod for Rescue Helo",
            "mnemonic": "useUH60mod",
            "defaultValue": false
        },
        {
            "nameInUI": "Rescue Duration (mins)",
            "mnemonic": "rescueDuration",
            "minimumValue": 1,
            "maximumValue": 30,
            "defaultValue": 3
        },
        {
            "nameInUI": "Rescue Zone Radius (nm)",
            "mnemonic": "rescueZoneRadius",
            "minimumValue": 5,
            "maximumValue": 120,
            "defaultValue": 15
        },
        {
            "nameInUI": "Recovery Window Start Time (mins)",
            "mnemonic": "windowStartOption",
            "minimumValue": 10,
            "maximumValue": 120,
            "defaultValue": 30
        },
        {
            "nameInUI": "Recovery Window Length (mins)",
            "mnemonic": "windowLengthOption",
            "minimumValue": 15,
            "maximumValue": 240,
            "defaultValue": 60
        },
        {
            "nameInUI": "Force Despawn AI Units after n minutes",
            "mnemonic": "despawnMinutesAfterLanding",
            "minimumValue": 0,
            "maximumValue": 30,
            "defaultValue": 5
        },
        {
            "nameInUI": "Enable OpenAI TTS (SRS ExternalAudio)",
            "mnemonic": "openaiTtsEnabled",
            "defaultValue": false
        },
        {
            "nameInUI": "OpenAI API Key",
            "mnemonic": "openaiApiKey",
            "defaultValue": ""
        },
        {
            "nameInUI": "OpenAI TTS Model",
            "mnemonic": "openaiModel",
            "defaultValue": "gpt-4o-mini-tts"
        },
        {
            "nameInUI": "OpenAI Voice",
            "mnemonic": "openaiVoice",
            "defaultValue": "alloy"
        },
        {
            "nameInUI": "OpenAI Audio Format",
            "mnemonic": "openaiFormat",
            "defaultValue": "mp3"
        },
        {
            "nameInUI": "OpenAI Speech Speed",
            "mnemonic": "openaiSpeed",
            "minimumValue": 0.5,
            "maximumValue": 2.0,
            "defaultValue": 1.0
        },
        {
            "nameInUI": "OpenAI API Base URL",
            "mnemonic": "openaiBaseUrl",
            "defaultValue": "https://api.openai.com/v1/audio/speech"
        }
    ],

